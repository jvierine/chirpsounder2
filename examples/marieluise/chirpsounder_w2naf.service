[Unit]
Description=Chirpsounder W2NAF receiver
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/hamsci/src/chirpsounder2
ExecStart=/usr/bin/bash /home/hamsci/src/chirpsounder2/examples/marieluise/w2naf.sh
Restart=always
RestartSec=5
KillMode=control-group
TimeoutStopSec=20

[Install]
WantedBy=default.target
